{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "bunVersion": "1.x",
  "devCommand": "bun run dev",
  "cleanUrls": true,
  "trailingSlash": false,
  "crons": [
    {
      "path": "/api/cron/telegram-heartbeat",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/sync-maintenance",
      "schedule": "17 4 * * *"
    }
  ],
  "headers": [
    {
      "source": "/:path*",
      "headers": [
        {
          "key": "Content-Security-Policy-Report-Only",
          "value": "default-src 'self'; base-uri 'self'; object-src 'none'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https:; style-src 'self' 'unsafe-inline' https:; img-src 'self' data: blob: https:; font-src 'self' data: https:; connect-src 'self' https: wss:; media-src 'self' blob: https:; frame-src 'self' https:; worker-src 'self' blob:; form-action 'self' https:; frame-ancestors 'self'"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "X-Permitted-Cross-Domain-Policies",
          "value": "none"
        }
      ]
    },
    {
      "source": "/embed/infinite-mac",
      "headers": [
        {
          "key": "Cross-Origin-Embedder-Policy",
          "value": "credentialless"
        },
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin"
        }
      ]
    },
    {
      "source": "/embed/pc",
      "headers": [
        {
          "key": "Cross-Origin-Embedder-Policy",
          "value": "credentialless"
        },
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin"
        }
      ]
    },
    {
      "source": "/fonts/:path*",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/wallpapers/tiles/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/wallpapers/photos/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/wallpapers/thumbs/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/wallpapers/videos/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/icons/default/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/icons/macosx/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/icons/system7/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/icons/win98/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/icons/xp/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/sounds/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/assets/games/jsdos/:path*",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/zip"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/patterns/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/:path(apple-touch-icon.png|favicon.ico)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/data/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/:path(manifest.json)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/wallpapers/manifest.json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/wallpapers/placeholders.json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, stale-while-revalidate=604800"
        }
      ]
    },
    {
      "source": "/icons/manifest.json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/:path(index.html|sw.js|registerSW.js)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/version.json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/embed/infinite-mac", "destination": "/embed/infinite-mac.html" },
    { "source": "/embed/pc", "destination": "/embed/pc.html" },
    { "source": "/videos/:video", "destination": "/" },
    { "source": "/ipod/:track", "destination": "/" },
    { "source": "/karaoke/:track", "destination": "/" },
    { "source": "/internet-explorer/:code", "destination": "/" },
    { "source": "/applet-viewer/:code", "destination": "/" },
    { "source": "/finder", "destination": "/" },
    { "source": "/soundboard", "destination": "/" },
    { "source": "/chats", "destination": "/" },
    { "source": "/textedit", "destination": "/" },
    { "source": "/paint", "destination": "/" },
    { "source": "/photo-booth", "destination": "/" },
    { "source": "/minesweeper", "destination": "/" },
    { "source": "/videos", "destination": "/" },
    { "source": "/tv", "destination": "/" },
    { "source": "/ipod", "destination": "/" },
    { "source": "/karaoke", "destination": "/" },
    { "source": "/applet-viewer", "destination": "/" },
    { "source": "/synth", "destination": "/" },
    { "source": "/pc", "destination": "/" },
    { "source": "/terminal", "destination": "/" },
    { "source": "/control-panels", "destination": "/" },
    { "source": "/infinite-mac", "destination": "/" },
    { "source": "/winamp", "destination": "/" },
    { "source": "/stickies", "destination": "/" },
    { "source": "/dashboard", "destination": "/" },
    { "source": "/listen/:sessionId", "destination": "/" }
  ],
  "redirects": [
    { "source": "/docs", "destination": "/docs/overview", "permanent": false },
    { "source": "/docs/", "destination": "/docs/overview", "permanent": false },
    { "source": "/privacy", "destination": "/docs/privacy", "permanent": false },
    { "source": "/privacy/", "destination": "/docs/privacy", "permanent": false },
    { "source": "/terms", "destination": "/docs/terms", "permanent": false },
    { "source": "/terms/", "destination": "/docs/terms", "permanent": false },
    { "source": "/404", "destination": "/", "permanent": false }
  ]
}
