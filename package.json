    "generate:app-docs": "bun run scripts/generate-app-docs.ts",
    "generate:changelog": "bun run scripts/generate-changelog.ts",
    "generate:docs": "bun run scripts/generate-app-docs.ts && bun run scripts/generate-docs.ts",
    "generate:docs:full": "bun run scripts/generate-app-docs.ts && bun run scripts/generate-changelog.ts --force && bun run scripts/generate-docs.ts",
    "launch-kiosk": "bash scripts/launch-kiosk.sh",
    "i18n:extract": "bun run scripts/extract-strings.ts",
    "i18n:generate-shell": "bun run scripts/generate-i18n-shell.ts",
    "i18n:sync": "bun run scripts/sync-translations.ts",
