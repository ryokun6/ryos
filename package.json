{
  "name": "ryos",
  "productName": "ryOS",
  "private": true,
  "version": "1.0.8",
  "description": "A web-based desktop operating system, reimagining classic Mac OS, Windows, and more.",
  "author": "Ryo Lu <me@ryo.lu> (https://ryo.lu)",
  "homepage": "https://os.ryo.lu",
  "license": "AGPL-3.0-only",
  "type": "module",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "dev": "bun run scripts/dev-with-api.ts",
    "dev:vite": "NODE_OPTIONS='--max-old-space-size=4096' vite --port ${PORT:-5173}",
    "dev:api": "TRUSTED_PROXY_COUNT=1 bun --watch scripts/api-standalone-server.ts",
    "api:start": "NODE_ENV=production bun run scripts/api-standalone-server.ts",
    "start": "NODE_ENV=production bun run scripts/api-standalone-server.ts",
    "version:bump": "bun run scripts/generate-build-version.ts --bump",
    "prebuild": "bun run scripts/generate-build-version.ts",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "generate:icons": "bun run scripts/generate-icon-manifest.ts",
    "generate:infinite-mac-thumbnails": "bun run scripts/generate-infinite-mac-thumbnails.ts",
    "generate:infinite-pc-thumbnails": "bun run scripts/generate-infinite-pc-thumbnails.ts",
    "generate:average-colors": "bun run scripts/compute-average-colors.ts",
    "generate:wallpapers": "bun run scripts/generate-wallpaper-manifest.ts && node --experimental-strip-types scripts/generate-wallpaper-placeholders.ts",
    "generate:wallpaper-placeholders": "node --experimental-strip-types scripts/generate-wallpaper-placeholders.ts",
    "generate:app-docs": "bun run scripts/generate-app-docs.ts",
    "generate:changelog": "bun run scripts/generate-changelog.ts",
    "generate:docs": "bun run scripts/generate-app-docs.ts && bun run scripts/generate-changelog.ts && bun run scripts/generate-docs.ts",
    "launch-kiosk": "bash scripts/launch-kiosk.sh",
    "i18n:extract": "bun run scripts/extract-strings.ts",
    "i18n:sync": "bun run scripts/sync-translations.ts",
    "i18n:sync:dry-run": "bun run scripts/sync-translations.ts --dry-run",
    "i18n:sync:mark-todo": "bun run scripts/sync-translations.ts --mark-untranslated",
    "i18n:find-untranslated": "bun run scripts/find-untranslated-strings.ts",
    "i18n:translate": "bun run scripts/machine-translate.ts",
    "i18n:translate:dry-run": "bun run scripts/machine-translate.ts --dry-run",
    "electron:bundle": "bun run scripts/bundle-electron.ts",
    "electron:dev": "bun run scripts/bundle-electron.ts --dev",
    "electron:build": "bun run scripts/build-electron.ts",
    "electron:build:mac": "bun run scripts/build-electron.ts --mac",
    "electron:build:windows": "bun run scripts/build-electron.ts --win",
    "electron:github-secrets": "bun run scripts/generate-github-electron-secrets.ts",
    "seed:dev": "bun run scripts/seed-dev-users.ts",
    "telegram:webhook": "bun run scripts/setup-telegram-webhook.ts",
    "test": "bun test",
    "test:abortable-fetch": "bun test tests/test-abortable-fetch.test.ts",
    "test:registration": "bun run scripts/check-test-registration.ts",
    "test:unit": "bun run scripts/run-test-group.ts unit",
    "test:api": "bun run scripts/run-test-group.ts api",
    "test:api-validation": "bun test tests/test-api-validation.test.ts",
    "test:new-api": "bun test tests/test-new-api.test.ts",
    "test:admin": "bun test tests/test-admin.test.ts",
    "test:iframe-check": "bun test tests/test-iframe-check.test.ts",
    "test:link-preview": "bun test tests/test-link-preview.test.ts",
    "test:parse-title": "bun test tests/test-parse-title.test.ts",
    "test:speech": "bun test tests/test-speech.test.ts",
    "test:share-applet": "bun test tests/test-share-applet.test.ts",
    "test:song": "bun test tests/test-song.test.ts",
    "test:sync-v2:unit": "bun test tests/test-sync-v2-core.test.ts tests/test-songs-tombstone-sync.test.ts tests/test-sync-maintenance.test.ts tests/test-sync-v2-codecs.test.ts",
    "test:sync-v2": "bun run test:sync-v2:unit && bun test tests/test-sync-v2-api.test.ts",
    "test:ai": "bun test tests/test-ai.test.ts",
    "test:media": "bun test tests/test-media.test.ts",
    "test:auth-extra": "bun test tests/test-auth-extra.test.ts",
    "test:auth-ban-lockout": "bun test tests/test-auth-ban-lockout.test.ts",
    "test:rooms-extra": "bun test tests/test-rooms-extra.test.ts",
    "test:listen-security": "bun test tests/test-listen-security.test.ts",
    "test:chat-notifications": "bun test tests/test-chat-notification-logic.test.ts",
    "test:chat-notification-wiring": "bun test tests/test-chat-notification-integration-wiring.test.ts",
    "test:chat-broadcast-wiring": "bun test tests/test-chat-broadcast-wiring.test.ts",
    "test:chat-hook-lifecycle": "bun test tests/test-chat-hook-channel-lifecycle-wiring.test.ts",
    "test:chat-store-guards": "bun test tests/test-chat-store-guards-wiring.test.ts",
    "test:chat-wiring": "bun test --filter 'chat-notification|chat-broadcast|chat-hook|chat-store'",
    "test:pusher-client": "bun test tests/test-pusher-client-refcount.test.ts",
    "test:pusher-constructor-wiring": "bun test tests/test-pusher-client-constructor-wiring.test.ts",
    "test:pusher-regression": "bun test --filter 'pusher'",
    "test:chat-regression": "bun test --filter 'chat-|pusher'",
    "test:realtime-auth": "bun test tests/test-realtime-auth.test.ts tests/test-realtime-channels.test.ts",
    "test:realtime-ws-local": "bun test tests/test-realtime-ws-local.test.ts"
  },
