    "test:media": "bun test tests/test-media.test.ts",
    "test:auth-extra": "bun test tests/test-auth-extra.test.ts",
    "test:rooms-extra": "bun test tests/test-rooms-extra.test.ts",
    "test:listen-security": "bun test tests/test-listen-security.test.ts",
